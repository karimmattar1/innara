# =============================================================================
# Innara — Production Environment Variables
# =============================================================================
# Copy to your Vercel project settings (Settings → Environment Variables)
# All values are REQUIRED for production deployment unless noted otherwise.
# =============================================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://hbqcujxpphwgkgrqpjmo.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=           # Project Settings → API → anon/public key
SUPABASE_SERVICE_ROLE_KEY=               # Project Settings → API → service_role key (NEVER expose client-side)

# Anthropic (AI Concierge)
ANTHROPIC_API_KEY=                       # https://console.anthropic.com/settings/keys

# Stripe (Billing)
STRIPE_SECRET_KEY=                       # Stripe Dashboard → Developers → API keys (use live key)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=      # Stripe Dashboard → Developers → API keys (publishable)
STRIPE_WEBHOOK_SECRET=                   # Stripe Dashboard → Developers → Webhooks → Signing secret

# Resend (Transactional Email)
RESEND_API_KEY=                          # https://resend.com/api-keys

# Upstash (Rate Limiting)
UPSTASH_REDIS_REST_URL=                  # Upstash Console → Redis → REST API URL
UPSTASH_REDIS_REST_TOKEN=               # Upstash Console → Redis → REST API Token

# Sentry (Error Monitoring)
NEXT_PUBLIC_SENTRY_DSN=                  # Sentry → Project Settings → Client Keys (DSN)
SENTRY_AUTH_TOKEN=                       # Sentry → Settings → Auth Tokens (for source maps)

# App Configuration
NEXT_PUBLIC_APP_URL=https://app.innara.io
NEXT_PUBLIC_APP_NAME=Innara
