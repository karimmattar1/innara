{
  "$schema": "https://raw.githubusercontent.com/nicholasray/lighthouse-ci/main/src/config/schema.json",
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3001/auth/guest/login",
        "http://localhost:3001/auth/staff/login",
        "http://localhost:3001/offline"
      ],
      "startServerCommand": "npm run build && npm run start -- --port 3001",
      "startServerReadyPattern": "Ready",
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.85 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.8 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 2000 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 300 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
